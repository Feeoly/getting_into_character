# 仅密钥必填（百炼）。其余在代码里已有默认值，仅在要覆盖时再加环境变量。
# 本地可不建 .env.local，用：export BAILIAN_API_KEY=sk-... && npm run dev
# 腾讯云等：控制台或 docker -e 只配 BAILIAN_API_KEY 即可。

BAILIAN_API_KEY=

# 可选：覆盖默认 https://coding.dashscope.aliyuncs.com/v1
# BAILIAN_BASE_URL=

# 可选：覆盖默认 MiniMax-M2.5
# BAILIAN_CHAT_MODEL=

# 可选：覆盖默认 https://hf-mirror.com（海外可设 https://huggingface.co）
# HF_HUB_UPSTREAM=

# 可选：与 HF_HUB_UPSTREAM 二选一
# HUGGINGFACE_HUB_ENDPOINT=

# 可选：1 = Worker 直连 Hub；默认走同源 /api/hf
# NEXT_PUBLIC_HF_HUB_DIRECT=
