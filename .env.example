# 复制为 .env.local 后填写真值；勿提交 .env.local。云上在主机/容器环境变量里配置同名项。

# 可选：国内拉模型走镜像（与代码中 HF 代理一致）
HF_HUB_UPSTREAM=https://hf-mirror.com
# 与上一项二选一，语义相同
# HUGGINGFACE_HUB_ENDPOINT=

# 复盘 Chat API（服务端读取，勿加 NEXT_PUBLIC_）
BAILIAN_API_KEY=
BAILIAN_BASE_URL=
# 可选，不填则用代码内默认模型名
# BAILIAN_CHAT_MODEL=

# 可选：设为1 时 Worker 直连 Hub（一般保持未设置，走同源 /api/hf）
# NEXT_PUBLIC_HF_HUB_DIRECT=
